@namespace projeto_carlos.Components.UI

<div class="mb-5">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">
            @Label
        </label>
    }

    <div class="relative flex items-center">
        @if (LeftIcon != null)
        {
            <div class="absolute left-4 z-10 flex items-center justify-center pointer-events-none text-slate-400">
                @LeftIcon
            </div>
        }
        <input
            type="@CurrentType"
            class="@GetInputClasses()"
            placeholder="@Placeholder"
            value="@Value"
            @oninput="OnInputChanged"
            disabled="@Disabled"/>
        @if (IsPassword)
        {
            <button
                type="button"
                class="absolute right-4 z-10 flex items-center text-slate-400 hover:text-primary transition-colors focus:outline-none"
                @onclick="TogglePasswordVisibility">
                
                <span class="material-symbols-outlined text-xl">
                    @(_showPassword ? "visibility_off" : "visibility")
                </span>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public bool IsPassword { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? LeftIcon { get; set; }
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private bool _showPassword = false;
    private string CurrentType => IsPassword && !_showPassword ? "password" : Type;
    
    private string GetInputClasses()
    {
        var baseClasses = "w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none placeholder:text-slate-400";
        var paddingY = "py-4";
        var paddingLeft = LeftIcon != null ? "pl-12" : "pl-4"; 
        var paddingRight = IsPassword ? "pr-12" : "pr-4";
        var disabledClasses = Disabled ? "bg-gray-100 opacity-70 cursor-not-allowed" : "";

        return $"{baseClasses} {paddingY} {paddingLeft} {paddingRight} {disabledClasses}".Trim();
    }
    
    private async Task OnInputChanged(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(newValue); 
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;
}