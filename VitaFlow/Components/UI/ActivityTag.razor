@namespace projeto_carlos.Components.UI

<button 
    type="button"
    class="@GetClasses()"
    @onclick="HandleClick">
    
    @if (Icon != null)
    {
        <span class="mr-2 flex items-center justify-center text-[18px] @(IsActive ? "text-blue-500" : "text-slate-500")">
            @Icon
        </span>
    }
    
    <span class="text-[13px] font-semibold @(IsActive ? "text-blue-600" : "text-slate-700")">
        @Label
    </span>
</button>

@code {
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }

    private string GetClasses()
    {
        var baseClasses = "inline-flex items-center justify-center px-[18px] py-[10px] rounded-full transition-all cursor-pointer focus:outline-none select-none border";
        
        var activeClasses = IsActive 
            ? "bg-blue-50 border-blue-400 shadow-sm" 
            : "bg-white border-slate-300 shadow-sm hover:border-slate-400";

        return $"{baseClasses} {activeClasses}";
    }

    private async Task HandleClick()
    {
        if (OnSelect.HasDelegate)
        {
            await OnSelect.InvokeAsync();
        }
    }
}
