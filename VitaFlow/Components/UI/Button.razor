@using projeto_carlos.Components.UI
@using projeto_carlos.Enums

<button 
    type="@Type"
    class="@GetClasses()"
    disabled="@Disabled"
    @onclick="HandleClick">

    @ChildContent
</button>

@code {
    
    [Parameter]
    public EButtonVariant Variant { get; set; } = EButtonVariant.Primary; 

    [Parameter]
    public string Type { get; set; } = "button"; 

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string CssClass { get; set; } = ""; 
    
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    
    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetClasses()
    {
        var baseClasses = "inline-flex justify-center items-center px-4 py-3 text-sm font-semibold rounded-xl transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2";
        var variantClasses = Variant.ToTailwindClasses();
        var disabledClasses = Disabled ? "opacity-50 cursor-not-allowed" : "";
        return $"{baseClasses} {variantClasses} {disabledClasses} {CssClass}".Trim();
    }

    private async Task HandleClick()
    {
        if (!Disabled && OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
    }
}