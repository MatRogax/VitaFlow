@using projeto_carlos.Enums
@using projeto_carlos.Models
@using projeto_carlos.Models.Entities

<div class="bg-white rounded-2xl p-6 flex flex-col items-center shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
    
    <div class="relative mb-4">
        <div class="w-20 h-20 rounded-full @Psychologist.Avatar flex items-center justify-center text-white text-xl font-bold">
            @GetInitials(Psychologist.Name)
        </div>
        <div class="absolute bottom-0 right-1 w-4 h-4 bg-green-500 border-2 border-white rounded-full"></div>
    </div>

    <h3 class="font-bold text-gray-900 text-lg text-center leading-tight">@Psychologist.Name</h3>
    <p class="text-sm text-blue-500 font-medium mt-1 text-center">@Psychologist.Specialty</p>
    
    <div class="flex items-center space-x-1 mt-2 mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-yellow-400">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-semibold text-gray-700">@Psychologist.Note.ToString("0.0")</span>
        <span class="text-xs text-gray-400">(@Psychologist.TotalEvaluations reviews)</span>
    </div>

    <Button Variant="EButtonVariant.Primary" CssClass="w-full" OnClick="OnScheduleClick">
        Agendar Sessão
    </Button>
</div>

@code {

    [Parameter, EditorRequired] 
    public PsychologistModel Psychologist { get; set; } = default!;
    
    [Parameter] 
    public EventCallback<int> OnSchedule { get; set; }

    private async Task OnScheduleClick()
    {
        if (OnSchedule.HasDelegate)
        {
            await OnSchedule.InvokeAsync(Psychologist.Id); 
        }
    }
    
    private string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "";
        
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var realName = parts.Where(p => !p.StartsWith("Dr")).ToArray();
        
        if (realName.Length == 0) return "";
        if (realName.Length == 1) return realName[0].Substring(0, 1).ToUpper();
        
        return (realName[0].Substring(0, 1) + realName[1].Substring(0, 1)).ToUpper();
    }
}