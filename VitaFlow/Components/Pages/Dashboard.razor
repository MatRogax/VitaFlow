@page "/dashboard"
@using projeto_carlos.Components.UI
@using projeto_carlos.Enums

<div class="px-8 md:px-12 py-10 w-full max-w-7xl mx-auto flex flex-col gap-10">
    <div class="flex flex-col gap-1">
        <h1 class="text-3xl md:text-[2rem] font-black text-slate-800 tracking-tight">
            Como você está se sentindo hoje, <span class="text-primary tracking-normal">Carlos</span>?
        </h1>
        <p class="text-slate-500 text-lg font-medium">
            Estamos aqui para cuidar de você e do seu bem-estar mental.
        </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-3xl p-8 flex flex-col shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-3xl">mood</span>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3">Registrar Humor</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-6">
                Acompanhe suas emoções e identifique padrões ao longo da semana.
            </p>
            <a href="#" class="text-primary font-bold text-sm flex items-center gap-1 hover:underline group">
                Iniciar agora <span class="material-symbols-outlined text-base group-hover:translate-x-0.5 transition-transform">chevron_right</span>
            </a>
        </div>
        <div class="bg-white rounded-3xl p-8 flex flex-col shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-purple-50 text-purple-500 flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-3xl">psychology</span>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3">Buscar Psicólogo</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-6">
                Encontre o profissional ideal para suas necessidades e agende uma conversa.
            </p>
            <a href="#" class="text-purple-600 font-bold text-sm flex items-center gap-1 hover:underline group">
                Ver especialistas <span class="material-symbols-outlined text-base group-hover:translate-x-0.5 transition-transform">chevron_right</span>
            </a>
        </div>
        <div class="bg-white rounded-3xl p-8 flex flex-col shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-green-50 text-green-500 flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-3xl">headphones</span>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-3">Ouvir Meditação</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-6">
                Pratique mindfulness com sessões guiadas para reduzir o estresse.
            </p>
            <a href="#" class="text-green-600 font-bold text-sm flex items-center gap-1 hover:underline group">
                Explorar áudios <span class="material-symbols-outlined text-base group-hover:translate-x-0.5 transition-transform">chevron_right</span>
            </a>
        </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 md:gap-12 mt-4">
        <div class="lg:col-span-2 flex flex-col gap-6">
            <div class="flex items-center justify-between">
                <h2 class="text-2xl font-bold text-slate-800">Suas próximas atividades</h2>
                <a href="#" class="text-sm font-bold text-primary hover:underline">Ver tudo</a>
            </div>
            <div class="bg-white rounded-3xl p-5 border border-slate-200 shadow-sm flex flex-col sm:flex-row items-center gap-5 hover:border-primary/30 transition-colors">
                <img src="https://i.pravatar.cc/150?u=draana" alt="Dra. Ana" class="w-16 h-16 rounded-full object-cover border-2 border-slate-100" />
                <div class="flex-1 text-center sm:text-left">
                    <h4 class="text-lg font-bold text-slate-800">Sessão com Dr. Carlos</h4>
                    <p class="text-sm text-slate-500 mb-1">Psicologia Cognitivo Comportamental</p>
                    <div class="flex items-center justify-center sm:justify-start gap-1 text-xs font-bold text-primary">
                        <span class="material-symbols-outlined text-[14px]">schedule</span>
                        Amanhã às 14:00
                    </div>
                </div>
                <Button Variant="EButtonVariant.Primary" CssClass="!py-2.5 !px-6 rounded-2xl w-full sm:w-auto shadow-none">
                    Entrar
                </Button>
            </div>
            <div class="bg-white rounded-3xl p-5 border border-slate-200 shadow-sm flex flex-col sm:flex-row items-center gap-5 hover:border-slate-300 transition-colors">
                <div class="w-16 h-16 rounded-3xl bg-slate-50 text-slate-400 flex items-center justify-center">
                    <span class="material-symbols-outlined text-3xl">headphones</span>
                </div>
                <div class="flex-1 text-center sm:text-left">
                    <h4 class="text-lg font-bold text-slate-800">Meditação: Alívio de Ansiedade</h4>
                    <p class="text-sm text-slate-500 mb-1">Sessão sugerida com base no seu humor</p>
                    <div class="flex items-center justify-center sm:justify-start gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-[14px]">schedule</span>
                        15 minutos
                    </div>
                </div>
                <button class="bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold px-6 py-2.5 rounded-2xl transition-colors w-full sm:w-auto">
                    Começar
                </button>
            </div>
        </div>
        <div class="lg:col-span-1 flex flex-col gap-6">
            <h2 class="text-2xl font-bold text-slate-800">Progresso Semanal</h2>
            <div class="bg-primary rounded-[2rem] p-8 text-white shadow-xl shadow-blue-500/30 relative overflow-hidden">
                <span class="material-symbols-outlined absolute top-8 right-8 text-white/30 text-5xl font-light">trending_up</span>
                <p class="text-sm font-medium text-white/80 mb-1">Humor médio</p>
                <h3 class="text-[2.5rem] font-bold leading-none mb-8">Estável</h3>
                <div class="mb-5">
                    <div class="flex justify-between text-sm font-semibold mb-2">
                        <span>Meta de meditação</span>
                        <span>80%</span>
                    </div>
                    <div class="w-full h-2 rounded-full bg-white/20">
                        <div class="h-full rounded-full bg-white w-4/5"></div>
                    </div>
                </div>
                <p class="text-[0.65rem] italic text-white/80 leading-relaxed font-medium">
                    "Você completou 4 sessões de mindfulness esta semana. Continue assim!"
                </p>
            </div>
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
                <h4 class="text-[15px] font-bold text-slate-800 mb-5">Como foi seu sono?</h4>
                <div class="flex justify-between items-center gap-2">
                    <button class="flex flex-col items-center gap-2 flex-1 pt-3 pb-4 rounded-2xl hover:bg-slate-50 transition-colors">
                        <span class="material-symbols-outlined text-3xl text-slate-800">sentiment_dissatisfied</span>
                        <span class="text-[10px] font-bold text-slate-500">RUIM</span>
                    </button>
                    <button class="flex flex-col items-center gap-2 flex-1 pt-3 pb-4 rounded-2xl hover:bg-slate-50 transition-colors">
                        <span class="material-symbols-outlined text-3xl text-slate-800">sentiment_neutral</span>
                        <span class="text-[10px] font-bold text-slate-500">OK</span>
                    </button>
                    <button class="flex flex-col items-center gap-2 flex-1 pt-3 pb-4 rounded-2xl bg-primary text-white shadow-md shadow-blue-500/20 transition-colors">
                        <span class="material-symbols-outlined text-3xl">sentiment_satisfied</span>
                        <span class="text-[10px] font-bold">BOM</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

