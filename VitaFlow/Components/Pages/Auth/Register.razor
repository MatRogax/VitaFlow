@page "/cadastro"
@using projeto_carlos.Components.UI
@using projeto_carlos.Components.Layout
@using projeto_carlos.Enums
@using projeto_carlos.Models
@using projeto_carlos.Models.ViewModels
@layout AuthLayout

@inject NavigationManager NavManager

<div class="relative flex min-h-[600px] w-full flex-col overflow-x-hidden">
    <div class="layout-container flex h-full grow flex-col">
        <AuthHeader>
            <RightContent>
                <div class="flex items-center gap-4">
                    <span class="hidden sm:inline text-sm text-text-muted">Já tem uma conta?</span>
                    <Button Variant="EButtonVariant.Outline" OnClick="GoToLogin" CssClass="min-w-[100px] !h-10 text-sm font-bold">
                        Entrar
                    </Button>
                </div>
            </RightContent>
        </AuthHeader>

        <main class="flex-1 flex items-center justify-center p-4 md:p-8 mt-24">
            <div class="w-full max-w-[520px] bg-bg-panel shadow-xl shadow-primary/5 rounded-xl border border-border-color p-8 md:p-12">
                
                <div class="flex flex-col gap-2 mb-8 text-center sm:text-left">
                    <h1 class="text-3xl font-black tracking-tight text-text-main">Criar Conta</h1>
                    <p class="text-text-muted text-base">Junte-se à nossa comunidade de cuidado e apoio emocional.</p>
                </div>
                
                <form @onsubmit="CompleteRegistration" class="flex flex-col gap-6">
                    
                    <SegmentedToggle 
                        Label="Eu sou:" 
                        @bind-Value="_registerViewModel.Perfil" />

                    <div class="grid grid-cols-1 gap-5">
                        <Input 
                            Label="Nome Completo" 
                            Placeholder="Como quer ser chamado?" 
                            @bind-Value="_registerViewModel.Nome">
                            <LeftIcon>
                                <span class="material-symbols-outlined text-xl">person</span>
                            </LeftIcon>
                        </Input>

                        <Input 
                            Label="E-mail" 
                            Type="email"
                            Placeholder="exemplo@email.com" 
                            @bind-Value="_registerViewModel.Email">
                            <LeftIcon>
                                <span class="material-symbols-outlined text-xl">mail</span>
                            </LeftIcon>
                        </Input>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <Input
                                Label="Senha" 
                                IsPassword="true"
                                Placeholder="••••••••" 
                                @bind-Value="_registerViewModel.Senha">
                                <LeftIcon>
                                    <span class="material-symbols-outlined text-xl">lock</span>
                                </LeftIcon>
                            </Input>

                            <Input 
                                Label="Confirmar Senha" 
                                IsPassword="true"
                                Placeholder="••••••••" 
                                @bind-Value="_registerViewModel.ConfirmarSenha">
                                <LeftIcon>
                                    <span class="material-symbols-outlined text-xl">lock_reset</span>
                                </LeftIcon>
                            </Input>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 mt-2">
                        <input id="termos" type="checkbox" @bind="_registerViewModel.AceitouTermos" class="mt-1 rounded border-border-color bg-bg-input text-primary focus:ring-primary h-4 w-4">
                        <label for="termos" class="text-xs text-text-muted leading-relaxed">
                            Ao clicar em Cadastrar, você concorda com nossos <a href="#" class="text-primary font-medium hover:underline">Termos de Uso</a> e <a href="#" class="text-primary font-medium hover:underline">Política de Privacidade</a>.
                        </label>
                    </div>

                    <Button Variant="EButtonVariant.Primary" Type="submit" CssClass="w-full h-14 flex items-center justify-center gap-2 group shadow-lg shadow-primary/20">
                        <span>Cadastrar</span>
                        <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </Button>
                </form>

                <div class="mt-8 pt-6 border-t border-border-color text-center">
                    <p class="text-sm text-text-muted">
                        Precisando de ajuda urgente? 
                        <a href="#" class="text-red-500 font-bold hover:underline ml-1">Ligue CVV 188</a>
                    </p>
                </div>
            </div>
        </main>

        <footer class="py-10 px-6 md:px-20 flex flex-col items-center gap-4 text-text-muted">
            <div class="flex gap-6">
                <a href="#" class="hover:text-primary transition-colors"><span class="material-symbols-outlined">social_leaderboard</span></a>
                <a href="#" class="hover:text-primary transition-colors"><span class="material-symbols-outlined">alternate_email</span></a>
                <a href="#" class="hover:text-primary transition-colors"><span class="material-symbols-outlined">share</span></a>
            </div>
            <p class="text-xs">© 2024 VitaFlow. Todos os direitos reservados.</p>
        </footer>
    </div>
</div>

@code {
    private readonly RegisterViewModel _registerViewModel = new();

    private void GoToLogin()
    {
        NavManager.NavigateTo("/login"); 
    }

    private void CompleteRegistration()
    {
        if (!_registerViewModel.AceitouTermos)
        {
            Console.WriteLine("Erro: Você precisa aceitar os termos.");
            return;
        }

        Console.WriteLine($"Cadastrando: {_registerViewModel.Nome}");
        Console.WriteLine($"Perfil escolhido: {_registerViewModel.Perfil}");
        
    }
    
}